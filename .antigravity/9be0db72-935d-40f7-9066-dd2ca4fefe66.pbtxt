  file_change {
    absolute_path_uri: "file:///src/components/PinLock.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useRef, useEffect } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Lock, Fingerprint } from \'lucide-react\';\n\ninterface PinLockProps {\n  moduleName: string;\n  description: string;\n  onUnlock: () => void;\n}\n\nexport function PinLock({ moduleName, description, onUnlock }: PinLockProps) {\n  const [pin, setPin] = useState([\'\', \'\', \'\', \'\']);\n  const [error, setError] = useState(false);\n  const inputs = useRef<(HTMLInputElement | null)[]>([]);\n\n  const handleChange = (index: number, value: string) => {\n    if (value.length > 1) return; // Prevent multiple chars\n    \n    const newPin = [...pin];\n    newPin[index] = value;\n    setPin(newPin);\n    setError(false);\n\n    // Auto focus next\n    if (value !== \'\' && index < 3) {\n      inputs.current[index + 1]?.focus();\n    }\n\n    // Check unlock\n    if (index === 3 && value !== \'\') {\n      if (newPin.join(\'\') === \'1234\') { // Mock PIN is 1234\n        onUnlock();\n      } else {\n        setError(true);\n        setTimeout(() => {\n          setPin([\'\', \'\', \'\', \'\']);\n          setError(false);\n          inputs.current[0]?.focus();\n        }, 500);\n      }\n    }\n  };\n\n  const handleKeyDown = (index: number, e: React.KeyboardEvent<HTMLInputElement>) => {\n    if (e.key === \'Backspace\' && pin[index] === \'\' && index > 0) {\n      inputs.current[index - 1]?.focus();\n    }\n  };\n\n  useEffect(() => {\n    inputs.current[0]?.focus();\n  }, []);\n\n  return (\n    <div className=\"absolute inset-0 z-50 flex items-center justify-center bg-surface/20 backdrop-blur-[32px]\">\n      <motion.div \n        initial={{ opacity: 0, scale: 0.95, y: 20 }}\n        animate={{ opacity: 1, scale: 1, y: 0 }}\n        className=\"w-[420px] bg-surface-container-high/80 backdrop-blur-[40px] border border-white/20 rounded-[40px] p-10 flex flex-col items-center relative overflow-hidden shadow-[0_30px_80px_rgba(0,0,0,0.5),inset_1px_1px_0px_rgba(255,255,255,0.2)]\"\n      >\n        <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-primary/20 blur-[60px] pointer-events-none rounded-full\"></div>\n        \n        <div className=\"w-20 h-20 rounded-full bg-gradient-to-b from-primary-container/20 to-transparent flex items-center justify-center mb-6 border border-primary/20 shadow-[0_0_30px_rgba(255,180,166,0.15)]\">\n          <Lock className=\"w-10 h-10 text-primary\" strokeWidth={1.5} />\n        </div>\n\n        <h2 className=\"text-[32px] font-bold text-on-surface mb-2 tracking-tight text-center leading-tight\">Module Locked</h2>\n        <p className=\"text-[16px] text-on-surface-variant text-center mb-10 max-w-[280px]\">\n          {description}\n          <br/>\n          <span className=\"text-xs opacity-50 mt-1 block\">(Hint: 1234)</span>\n        </p>\n\n        <motion.div \n          animate={error ? { x: [-10, 10, -10, 10, 0] } : {}}\n          transition={{ duration: 0.4 }}\n          className=\"flex gap-4 mb-12\"\n        >\n          {pin.map((digit, index) => (\n            <input\n              key={index}\n              ref={(el) => inputs.current[index] = el}\n              type=\"password\"\n              maxLength={1}\n              value={digit}\n              onChange={(e) => handleChange(index, e.target.value)}\n              onKeyDown={(e) => handleKeyDown(index, e)}\n              className=\"pin-cell-input w-16 h-20 rounded-2xl bg-surface-container-lowest/80 border border-white/10 text-center text-5xl font-bold text-primary focus:outline-none focus:border-primary focus:bg-surface/90 focus:shadow-[0_0_20px_rgba(255,180,166,0.3),inset_0_0_10px_rgba(255,180,166,0.1)] transition-all duration-300 placeholder:text-transparent caret-transparent glass-edge\"\n            />\n          ))}\n        </motion.div>\n\n        <div className=\"flex justify-between w-full px-4\">\n          <button className=\"text-xs font-semibold text-on-surface-variant hover:text-primary transition-colors underline-offset-4 hover:underline\">\n            Emergency Exit\n          </button>\n          <button className=\"text-xs font-semibold text-on-surface-variant hover:text-primary transition-colors flex items-center gap-1\">\n            <Fingerprint className=\"w-4 h-4\" />\n            Biometrics\n          </button>\n        </div>\n      </motion.div>\n    </div>\n  );\n}\n"
    }
