flex-col items-center bg-surface-container/30 p-4 rounded-xl border border-white/5\">\n            <div className=\"relative w-24 h-24 mb-3\">\n              <svg className=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 100 100\">\n                <circle cx=\"50\" cy=\"50\" fill=\"transparent\" r=\"40\" strokeWidth=\"12\" className=\"text-surface-variant stroke-current\" />\n                <circle cx=\"50\" cy=\"50\" fill=\"transparent\" r=\"40\" strokeWidth=\"12\" className=\"stroke-current\" strokeDasharray=\"251.2\" strokeDashoffset=\"150.72\" strokeLinecap=\"round\" style={{ stroke: \'#00ffff\', filter: \'drop-shadow(0 0 8px rgba(0,255,255,0.8))\' }} />\n              </svg>\n              <div className=\"absolute inset-0 flex items-center justify-center\">\n                <span className=\"text-2xl font-bold text-on-surface\">40%</span>\n              </div>\n            </div>\n            <h4 className=\"text-xs font-semibold uppercase tracking-wider text-on-surface text-center mt-2\">Data Structures</h4>\n            <p className=\"text-xs text-on-surface-variant mt-1\">8/20 Modules</p>\n          </div>\n\n          <div className=\"flex flex-col items-center bg-surface-container/30 p-4 rounded-xl border border-white/5\">\n            <div className=\"relative w-24 h-24 mb-3\">\n              <svg className=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 100 100\">\n                <circle cx=\"50\" cy=\"50\" fill=\"transparent\" r=\"40\" strokeWidth=\"12\" className=\"text-surface-variant stroke-current\" />\n                <circle cx=\"50\" cy=\"50\" fill=\"transparent\" r=\"40\" strokeWidth=\"12\" className=\"stroke-current\" strokeDasharray=\"251.2\" strokeDashoffset=\"226.08\" strokeLinecap=\"round\" style={{ stroke: \'#ff6600\', filter: \'drop-shadow(0 0 8px rgba(255,102,0,0.8))\' }} />\n              </svg>\n              <div className=\"absolute inset-0 flex items-center justify-center\">\n                <span className=\"text-2xl font-bold text-on-surface\">10%</span>\n              </div>\n            </div>\n            <h4 className=\"text-xs font-semibold uppercase tracking-wider text-on-surface text-center mt-2\">Negotiation Tactics</h4>\n            <p className=\"text-xs text-on-surface-variant mt-1\">1/10 Modules</p>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"md:col-span-4 glass-card rounded-2xl p-6 flex flex-col items-center justify-center relative overflow-hidden h-fit pt-[120px]\">\n        <h3 className=\"text-2xl font-medium text-on-surface absolute top-6 left-6 z-10\">Skill Matrix</h3>\n        <div className=\"w-48 h-48 relative z-10 mb-8\">\n          <div className=\"absolute inset-0 rounded-full border border-white/20 flex items-center justify-center\">\n            <div className=\"w-32 h-32 rounded-full border border-white/20 flex items-center justify-center\">\n              <div className=\"w-16 h-16 rounded-full border border-white/20\"></div>\n            </div>\n          </div>\n          <div className=\"absolute top-0 bottom-0 left-1/2 w-[1px] bg-white/20 -translate-x-1/2\"></div>\n          <div className=\"absolute left-0 right-0 top-1/2 h-[1px] bg-white/20 -translate-y-1/2\"></div>\n          <div className=\"absolute top-0 bottom-0 left-1/2 w-[1px] bg-white/20 -translate-x-1/2 rotate-45\"></div>\n          <div className=\"absolute left-0 right-0 top-1/2 h-[1px] bg-white/20 -translate-y-1/2 rotate-45\"></div>\n          \n          <svg className=\"absolute inset-0 w-full h-full text-primary/40 fill-current drop-shadow-[0_0_15px_rgba(255,180,166,0.5)]\" viewBox=\"0 0 100 100\">\n            <polygon points=\"50,15 85,30 75,80 50,90 20,60 30,25\"></polygon>\n          </svg>\n          \n          <div className=\"absolute top-[15%] left-[50%] w-2 h-2 bg-primary rounded-full shadow-[0_0_8px_#ffb4a6] -translate-x-1/2 -translate-y-1/2\"></div>\n          <div className=\"absolute top-[30%] left-[85%] w-2 h-2 bg-primary rounded-full 