    replacement_chunks {
      replacement_content: "import { motion } from \'motion/react\';\nimport { PinLock } from \'../components/PinLock\';\n\nexport function StudyModule({ isUnlocked, onUnlock }: { isUnlocked: boolean, onUnlock: () => void }) {\n  if (!isUnlocked) {\n    return (\n      <div className=\"relative flex-1 flex items-center justify-center -m-8 px-8\">\n        {/* Background placeholder for locked state */}\n        <div className=\"absolute inset-0 opacity-20 blur-md pointer-events-none p-10 flex flex-col gap-6\">\n          <div className=\"h-64 glass-panel rounded-2xl w-2/3\"></div>\n          <div className=\"h-32 glass-panel rounded-2xl w-full\"></div>\n          <div className=\"h-32 glass-panel rounded-2xl w-full\"></div>\n        </div>\n        <PinLock \n          moduleName=\"Study\" \n          description=\"Enter your sanctuary PIN to access deep work flow.\" \n          onUnlock={onUnlock} \n        />\n      </div>\n    );\n  }\n\n  return (\n    <motion.div \n      initial={{ opacity: 0 }} animate={{ opacity: 1 }} \n      className=\"max-w-6xl w-full mx-auto grid grid-cols-12 gap-8 h-full\"\n    >\n      <div className=\"col-span-12 mb-4\">\n        <h2 className=\"text-[64px] font-bold text-on-surface tracking-tight mb-2 leading-none\">Deep Work</h2>\n        <p className=\"text-[18px] text-primary\">10-Hour Intensive Routine Active</p>\n      </div>\n\n      <div className=\"col-span-12 lg:col-span-8 flex flex-col gap-8\">\n        <div className=\"bg-surface-container/40 rounded-[32px] p-8 border border-white/5 glass-edge h-64 flex flex-col justify-between shadow-lg\">\n          <div className=\"flex justify-between items-center mb-6\">\n            <h3 className=\"text-2xl font-medium text-on-surface\">Daily Progress</h3>\n            <span className=\"text-secondary font-mono text-xl\">04:23 / 10:00</span>\n          </div>\n          <div className=\"flex-1 flex items-end gap-2\">\n            {[100, 0, 0, 0, 0].map((progress, i) => (\n              <div key={i} className=\"w-full h-full bg-white/5 rounded-lg relative overflow-hidden\">\n                <motion.div \n                  initial={{ height: 0 }}\n                  animate={{ height: `${progress}%` }}\n                  className=\"absolute bottom-0 left-0 w-full bg-gradient-to-t from-primary to-primary-container rounded-lg\"\n                />\n              </div>\n            ))}\n          </div>\n        </div>\n\n        <div className=\"bg-surface-container/30 rounded-[32px] p-8 border border-white/5 glass-edge flex-1 shadow-lg\">\n          <h3 className=\"text-2xl font-medium text-on-surface mb-6\">Active Curriculum</h3>\n          <div className=\"space-y-4\">\n            {[\n              { title: \'Advanced Algorithms\', subtitle: \'Module 4: Graph Theory\', icon: \'data_object\', color: \'secondary\' },\n              { title: \'Systems Architecture\', subtitle: \'Reviewing Cache Coherence\', icon: \'memory\', color: \'primary\' }\n            ].map((course, i) => (\n              <div key={i} className=\"flex items-center gap-4 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors cursor-pointer\">\n                <div className={`w-12 h-12 rounded-xl bg-${course.color}/20 flex items-center justify-center text-${course.color}`}>\n                  <span className=\"material-symbols-outlined\">{course.icon}</span>\n                </div>\n                <div className=\"flex-1\">\n                  <h4 className=\"text-[18px] text-on-surface\">{course.title}</h4>\n                  <p className=\"text-[12px] text-on-surface-variant font-semibold tracking-widest uppercase\">{course.subtitle}</p>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      <div className=\"col-span-12 lg:col-span-4 flex flex-col gap-8\">\n        <div className=\"bg-gradient-to-br from-surface-container to-surface rounded-[32px] p-8 border border-white/10 glass-edge text-center flex flex-col items-center justify-center h-80 relative overflow-hidden shadow-xl\">\n          <div className=\"absolute inset-0 bg-primary/5 blur-3xl rounded-full scale-150\"></div>\n          <h3 className=\"text-[18px] text-on-surface-variant relative z-10 mb-2\">Next Milestone</h3>\n          <div className=\"text-[80px] leading-none font-bold text-primary relative z-10 my-4 tracking-tighter\">14</div>\n          <p className=\"text-2xl text-on-surface relative z-10 font-medium\">Days Remaining</p>\n          <p className=\"text-[16px] text-on-surface-variant/70 relative z-10 mt-2\">Systems Final Exam</p>\n        </div>\n\n        <div className=\"bg-surface-container/30 rounded-[32px] p-6 border border-white/5 glass-edge flex-1 flex items-center justify-center shadow-lg\">\n          <div className=\"w-32 h-32 rounded-full border-[8px] border-secondary/20 border-t-secondary/80 flex items-center justify-center shadow-[0_0_20px_rgba(192,193,255,0.1)]\">\n            <span className=\"text-[32px] font-bold text-on-surface\">82%</span>\n          </div>\n        </div>\n      </div>\n    </motion.div>\n  );\n}"
