  file_change {
    absolute_path_uri: "file:///src/modules/LibraryModule.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \'motion/react\';\nimport { Filter, Grid, CheckCircle2, Edit3, MoreHorizontal, Plus } from \'lucide-react\';\n\nexport function LibraryModule() {\n  return (\n    <div className=\"max-w-[1400px] w-full mx-auto flex flex-col h-full gap-8\">\n      <div className=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-4\">\n        <div>\n          <h2 className=\"text-[64px] font-bold text-on-surface tracking-tight leading-none mb-4\">Library</h2>\n          <p className=\"text-[18px] text-on-surface-variant\">Your digital sanctuary of knowledge.</p>\n        </div>\n        <div className=\"flex gap-8 bg-surface-container/50 px-8 py-4 rounded-2xl border border-white/5 backdrop-blur-md\">\n          <div className=\"text-right\">\n            <p className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest mb-1\">Books Read</p>\n            <p className=\"text-[32px] font-bold text-primary leading-none\">42</p>\n          </div>\n          <div className=\"w-px bg-white/10 h-12 self-center\"></div>\n          <div className=\"text-right\">\n            <p className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest mb-1\">Pages Turned</p>\n            <p className=\"text-[32px] font-bold text-tertiary leading-none\">14,208</p>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-8 flex-1\">\n        <div className=\"xl:col-span-8 flex flex-col gap-8\">\n          <div className=\"glass-card rounded-[32px] p-8 flex flex-col md:flex-row gap-10 relative overflow-hidden group shadow-xl\">\n            <div className=\"absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none\"></div>\n            \n            <div className=\"w-40 md:w-56 shrink-0 rounded-xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.4)] relative z-10 border border-white/10 group-hover:scale-105 transition-transform duration-500\">\n              <img \n                src=\"https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=400&q=80\" \n                alt=\"Book cover\" \n                className=\"w-full h-full object-cover aspect-[2/3] filter saturate-50 contrast-125 hover:saturate-100 transition-all duration-500\"\n              />\n              <div className=\"absolute inset-0 bg-primary/10 mix-blend-overlay\"></div>\n            </div>\n            \n            <div className=\"flex-1 flex flex-col justify-center z-10\">\n              <span className=\"inline-block px-4 py-1.5 bg-surface-variant text-secondary text-[10px] rounded-full uppercase tracking-widest font-bold w-fit mb-6 border border-white/10 shadow-sm\">Currently Reading</span>\n              \n              <h3 className=\"text-[32px] font-medium text-on-surface mb-2 leading-tight\">The Architecture of Happiness</h3>\n              <p className=\"text-[18px] text-on-surface-variant mb-10\">Alain de Botton</p>\n              \n              <div className=\"mt-auto bg-surface-container-low/50 p-6 rounded-2xl border border-white/5\">\n                <div className=\"flex justify-between items-end mb-3\">\n                  <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">Progress</span>\n                  <span className=\"text-[16px] text-primary font-bold\">68% <span className=\"text-sm text-on-surface-variant font-normal\">/ p. 215 of 320</span></span>\n                </div>\n                <div className=\"h-2 w-full bg-surface-container-highest rounded-full overflow-hidden\">\n                  <div className=\"h-full bg-gradient-to-r from-primary to-secondary rounded-full relative shadow-[0_0_10px_rgba(255,180,166,0.5)]\" style={{width: \'68%\'}}>\n                    <div className=\"absolute right-0 top-0 w-4 h-full bg-white/50 blur-[4px]\"></div>\n                  </div>\n                </div>\n                \n                <div className=\"mt-8 flex gap-4\">\n                  <button className=\"px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-on-surface text-[12px] font-bold uppercase tracking-widest transition-all flex items-center gap-2 shadow-sm\">\n                    <Edit3 className=\"w-4 h-4\" /> Log Pages\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"flex-1\">\n            <div className=\"flex justify-between items-center mb-8\">\n              <h3 className=\"text-[32px] font-medium text-on-surface\">Collection</h3>\n              <div className=\"flex gap-2\">\n                <button className=\"p-3 rounded-xl bg-surface-container hover:bg-surface-container-high text-on-surface transition-colors border border-white/5 shadow-sm\"><Filter className=\"w-5 h-5\"/></button>\n                <button className=\"p-3 rounded-xl bg-surface-container hover:bg-surface-container-high text-on-surface transition-colors border border-white/5 shadow-sm\"><Grid className=\"w-5 h-5\"/></button>\n              </div>\n            </div>\n\n            <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-8\">\n              {[\n                { title: \'Thinking, Fast and Slow\', author: \'Daniel Kahneman\', img: \'https://images.unsplash.com/photo-1589829085413-56de8ae18c73?w=300&q=80\', completed: true },\n                { title: \'Deep Work\', author: \'Cal Newport\', img: \'https://images.unsplash.com/photo-1550399105-c4db5fb85c18?w=300&q=80\', progress: \'33%\', color: \'bg-secondary\' },\n                { title: \'Atomic Habits\', author: \'James Clear\', img: \'https://images.unsplash.com/photo-1589405858862-2ac9cbf4136e?w=300&q=80\', progress: \'100%\', color: \'bg-primary\', altText: \'Atomic Habits\' }\n              ].map((book, i) => (\n                <div key={i} className=\"group cursor-pointer flex flex-col\">\n                  <div className=\"relative rounded-xl overflow-hidden shadow-lg border border-white/10 aspect-[2/3] mb-4 transition-all duration-500 group-hover:-translate-y-2 group-hover:shadow-[0_15px_30px_rgba(0,0,0,0.4)]\">\n                    {book.img ? (\n                       <img src={book.img} className=\"w-full h-full object-cover filter saturate-50 contrast-125 group-hover:saturate-100 transition-all duration-500\" />\n                    ) : (\n                       <div className=\"w-full h-full bg-surface-container-highest flex items-center justify-center p-4 text-center border-t border-l border-white/5 bg-gradient-to-br from-surface to-surface-container\">\n                         <span className=\"text-[20px] text-on-surface/70 font-semibold leading-tight\">{book.altText}</span>\n                       </div>\n                    )}\n                    \n                    {book.completed && (\n                      <div className=\"absolute inset-0 bg-background/50 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center\">\n                        <CheckCircle2 className=\"w-12 h-12 text-primary drop-shadow-lg\" />\n                      </div>\n                    )}\n                    \n                    {book.progress && !book.completed && (\n                      <div className=\"absolute bottom-0 left-0 w-full h-1.5 bg-surface-container-high/80\">\n                        <div className={`h-full ${book.color}`} style={{width: book.progress}}></div>\n                      </div>\n                    )}\n                  </div>\n                  <h4 className=\"text-[16px] font-medium text-on-surface truncate px-1 group-hover:text-primary transition-colors\">{book.title}</h4>\n                  <p className=\"text-[12px] font-medium text-on-surface-variant truncate px-1 mt-1\">{book.author}</p>\n                </div>\n              ))}\n\n              <div className=\"group cursor-pointer flex flex-col\">\n                <div className=\"relative rounded-xl overflow-hidden border-2 border-white/10 border-dashed aspect-[2/3] mb-4 flex items-center justify-center bg-white/5 hover:bg-white/10 transition-colors hover:border-primary/50\">\n                  <Plus className=\"w-10 h-10 text-on-surface-variant group-hover:text-primary transition-colors group-hover:scale-110\" />\n                </div>\n                <h4 className=\"text-[16px] font-medium text-on-surface-variant text-center mt-2 group-hover:text-on-surface transition-colors\">Add Book</h4>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"xl:col-span-4 h-full min-h-[600px] flex flex-col\">\n          <div className=\"glass-card rounded-[32px] h-full p-8 flex flex-col border border-outline/20 shadow-xl\">\n            <div className=\"flex justify-between items-center mb-8\">\n              <div className=\"flex items-center gap-3\">\n                <span className=\"material-symbols-outlined text-tertiary text-[28px]\" style={{fontVariationSettings: \"\'FILL\' 1\"}}>format_quote</span>\n                <h3 className=\"text-[24px] font-medium text-on-surface\">Passages</h3>\n              </div>\n              <button className=\"text-on-surface-variant hover:text-on-surface p-2 bg-surface-container rounded-lg\"><MoreHorizontal className=\"w-5 h-5\"/></button>\n            </div>\n            \n            <div className=\"flex-1 overflow-y-auto pr-4 space-y-8 scrollbar-thin scrollbar-thumb-white/10 scrollbar-track-transparent\">\n              <div className=\"group relative pl-6 border-l-2 border-primary/30 hover:border-primary transition-colors\">\n                <p className=\"text-[18px] text-on-surface/90 italic leading-relaxed\">\n                  \"What we call the personality is often merely a collection of defensively organized habits.\"\n                </p>\n                <p className=\"text-[12px] font-semibold text-on-surface-variant mt-4 flex items-center gap-2 uppercase tracking-widest\">\n                  <span className=\"w-2 h-2 rounded-full bg-secondary shadow-[0_0_8px_rgba(192,193,255,0.8)]\"></span>\n                  The Architecture of Happiness, p. 84\n                </p>\n              </div>\n\n              <div className=\"group relative pl-6 border-l-2 border-tertiary/30 hover:border-tertiary transition-colors\">\n                <p className=\"text-[18px] text-on-surface/90 italic leading-relaxed\">\n                  \"To produce at your peak level you need to work for extended periods with full concentration on a single task free from distraction.\"\n                </p>\n                <p className=\"text-[12px] font-semibold text-on-surface-variant mt-4 flex items-center gap-2 uppercase tracking-widest\">\n                  <span className=\"w-2 h-2 rounded-full bg-tertiary shadow-[0_0_8px_rgba(137,206,255,0.8)]\"></span>\n                  Deep Work, p. 44\n                </p>\n              </div>\n            </div>\n\n            <div className=\"mt-8 pt-6 border-t border-white/10\">\n              <textarea \n                className=\"w-full bg-surface-container/30 border border-white/5 rounded-xl resize-none focus:ring-0 focus:border-primary/50 focus:bg-surface-container transition-colors text-on-surface text-[16px] placeholder-on-surface-variant/50 h-32 p-4 mb-4 backdrop-blur-sm\" \n                placeholder=\"Capture a thought or quote...\"\n              ></textarea>\n              <div className=\"flex justify-between items-center px-2\">\n                <div className=\"flex gap-4 text-on-surface-variant\">\n                  <button className=\"hover:text-primary transition-colors p-2\"><span className=\"material-symbols-outlined text-[20px]\">format_bold</span></button>\n                  <button className=\"hover:text-primary transition-colors p-2\"><span className=\"material-symbols-outlined text-[20px]\">format_italic</span></button>\n                  <button className=\"hover:text-primary transition-colors p-2\"><span className=\"material-symbols-outlined text-[20px]\">link</span></button>\n                </div>\n                <button className=\"px-6 py-2.5 bg-white/10 rounded-lg text-[12px] font-bold uppercase tracking-widest text-on-surface hover:bg-white/20 transition-colors shadow-sm border border-white/5\">Save</button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
