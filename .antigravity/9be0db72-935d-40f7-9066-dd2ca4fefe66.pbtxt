-color-expense-coral: #ff5252;\n  --color-p2p-indigo: #651fff;\n  --color-vibrant-cyan: #00e5ff;\n  --color-vibrant-pink: #ff4081;\n  --color-vibrant-amber: #ffab00;\n\n  --spacing-sidebar-width: 280px;\n  --spacing-container-padding: 32px;\n  --spacing-unit: 8px;\n  --spacing-gutter: 24px;\n  --spacing-card-gap: 20px;\n\n  --font-headline-lg-mobile: Geist, sans-serif;\n  --font-label-sm: Geist, sans-serif;\n  --font-headline-lg: Geist, sans-serif;\n  --font-body-md: Inter, sans-serif;\n  --font-headline-md: Geist, sans-serif;\n  --font-display-xl: Geist, sans-serif;\n  --font-body-lg: Inter, sans-serif;\n}\n\n/* Global Styles */\nbody {\n  font-family: var(--font-body-md);\n  color: var(--color-on-surface);\n  background-color: var(--color-background);\n}\n\n.aurora-bg {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100vw;\n  height: 100vh;\n  z-index: -1;\n  background-image: \n    radial-gradient(circle at 10% 20%, rgba(255, 126, 103, 0.15) 0%, transparent 50%),\n    radial-gradient(circle at 80% 10%, rgba(49, 49, 192, 0.15) 0%, transparent 50%),\n    radial-gradient(circle at 50% 80%, rgba(39, 174, 243, 0.15) 0%, transparent 50%),\n    radial-gradient(circle at 90% 90%, rgba(101, 31, 255, 0.1) 0%, transparent 50%);\n  background-color: var(--color-background);\n  animation: pulse-bg 20s ease-in-out infinite alternate;\n}\n\n@keyframes pulse-bg {\n  0% { transform: scale(1); filter: hue-rotate(0deg); }\n  50% { transform: scale(1.05); }\n  100% { transform: scale(1); filter: hue-rotate(10deg); }\n}\n\n.glass-card {\n  background: rgba(23, 31, 51, 0.4);\n  backdrop-filter: blur(24px);\n  -webkit-backdrop-filter: blur(24px);\n  border-top: 1px solid rgba(255, 255, 255, 0.15);\n  border-left: 1px solid rgba(255, 255, 255, 0.15);\n  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);\n}\n\n.glass-panel {\n  background: rgba(45, 52, 73, 0.4);\n  backdrop-filter: blur(24px);\n  -webkit-backdrop-filter: blur(24px);\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n  border-left: 1px solid rgba(255, 255, 255, 0.1);\n  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);\n}\n\n.glass-edge {\n  box-shadow: inset 1px 1px 0px rgba(255, 255, 255, 0.2);\n}\n\n.mesh-income {\n  background: linear-gradient(135deg, rgba(0, 230, 118, 0.1) 0%, rgba(0, 229, 255, 0.05) 100%);\n}\n.mesh-expense {\n  background: linear-gradient(135deg, rgba(255, 82, 82, 0.1) 0%, rgba(255, 64, 129, 0.05) 100%);\n}\n.mesh-p2p {\n  background: linear-gradient(135deg, rgba(101, 31, 255, 0.1) 0%, rgba(0, 229, 255, 0.05) 100%);\n}\n\n.pin-cell-input {\n  -webkit-text-security: disc;\n  text-security: disc;\n}\n\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n::-webkit-scrollbar-track {\n  background: transparent;\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 10px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n.progress-ring__circle {\n  transition: stroke-dashoffset 0.35s;\n  transform: rotate(-90deg);\n  transform-origin: 50% 50%;\n}\n\n.input-cell {\n  background: rgba(255,255,255,0.05);\n  border: 1px solid rgba(255,255,255,0.1);\n  color: var(--color-on-surface);\n  transition: all 0.2s ease;\n}\n.input-cell:focus {\n  outline: none;\n  border-color: var(--color-primary);\n  background: rgba(255, 180, 166, 0.1);\n}"
