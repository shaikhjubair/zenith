    absolute_path_uri: "file:///src/modules/DietModule.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \'motion/react\';\nimport { PinLock } from \'../components/PinLock\';\n\nexport function DietModule({ isUnlocked, onUnlock }: { isUnlocked: boolean, onUnlock: () => void }) {\n  if (!isUnlocked) {\n    return (\n      <div className=\"relative flex-1 flex items-center justify-center -m-8 px-8\">\n        <PinLock \n          moduleName=\"Diet\" \n          description=\"Authenticate to access specialized dietary protocols and trackers.\" \n          onUnlock={onUnlock} \n        />\n        <div className=\"absolute inset-0 z-10 grid grid-cols-12 gap-8 pointer-events-none p-8 pt-24 opacity-20\">\n          <div className=\"col-span-8 glass-panel border border-white/20 rounded-xl h-64\"></div>\n          <div className=\"col-span-4 glass-panel border border-white/20 rounded-xl h-64\"></div>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <motion.div \n      initial={{ opacity: 0 }} animate={{ opacity: 1 }} \n      className=\"max-w-6xl w-full mx-auto grid grid-cols-12 gap-8 h-full\"\n    >\n      <div className=\"col-span-8 row-span-2 bg-surface/60 backdrop-blur-xl border border-white/20 border-t-white/30 border-l-white/30 rounded-[32px] p-8 flex flex-col gap-6 shadow-[0_4px_30px_rgba(0,0,0,0.1)] glass-card\">\n        <div className=\"flex justify-between items-center mb-4\">\n          <h2 className=\"text-2xl font-medium text-primary\">Cyclical Planner</h2>\n          <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">Sat - Fri</span>\n        </div>\n        <div className=\"flex-1 flex gap-2\">\n          {[\'Sat\', \'Sun\', \'Mon\', \'Tue\', \'Wed\', \'Thu\', \'Fri\'].map((day, i) => {\n            const isToday = i === 2; // Mon\n            const isFast = i === 2 || i === 5;\n            \n            return (\n              <div key={day} className={`flex-1 rounded-xl bg-surface-container/50 border flex flex-col items-center py-4 relative overflow-hidden transition-colors ${isToday ? \'border-primary/40 shadow-[0_0_15px_rgba(255,180,166,0.1)]\' : isFast ? \'border-secondary/40\' : \'border-white/10 hover:border-white/20\'}`}>\n                {isToday && <div className=\"absolute inset-0 bg-primary/5\"></div>}\n                {isToday && <div className=\"absolute top-2 right-2 w-1.5 h-1.5 rounded-full bg-primary\"></div>}\n                <span className={`text-[12px] font-semibold tracking-wider uppercase mb-2 ${isToday ? \'text-primary\' : isFast ? \'text-secondary\' : \'text-on-surface-variant\'}`}>{day}</span>\n                {isFast && <span className=\"text-xs text-on-surface-variant mt-1 mb-2\">Fast</span>}\n                <div className={`w-10 h-10 rounded-full border-2 flex items-center justify-center mt-auto ${isToday ? \'border-primary text-primary font-bold\' : isFast ? \'border-secondary text-secondary font-bold\' : \'border-primary/30 text-on-surface/50\'}`}>\n                  {i === 0 ? \'2.4k\' : i === 1 ? \'2.0k\' : i === 2 || i === 5 ? \'0\' : \'--\'}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n\n      <div className=\"col-span-4 bg-surface/60 backdrop-blur-xl border border-white/20 border-t-white/30 border-l-white/30 rounded-[32px] p-6 flex flex-col justify-between glass-card transition-transform hover:-translate-y-1\">\n        <div>\n          <h3 className=\"text-[16px] text-on-surface-variant mb-1 font-medium\">Hydration</h3>\n          <div className=\"text-[32px] font-bold text-tertiary tracking-tight\">2.4L</div>\n        </div>\n        <div className=\"flex gap-2 flex-wrap mt-4\">\n          {[1,2,3,4,5,6].map((i) => (\n             <div key={i} className={`w-8 h-10 rounded ${i <= 3 ? \'bg-tertiary/20 border-tertiary/50\' : \'bg-surface-container border-white/10\'} border`}></div>\n          ))}\n        </div>\n      </div>\n\n      <div className=\"col-span-4 bg-surface/60 backdrop-blur-xl border border-white/20 border-t-white/30 border-l-white/30 rounded-[32px] p-6 flex items-center justify-between glass-card transition-transform hover:-translate-y-1\">\n        <div>\n          <h3 className=\"text-[16px] text-on-surface-variant mb-1 font-medium\">Fasting</h3>\n          <p className=\"text-[12px] font-semibold text-primary uppercase tracking-widest\">Active: 14h 22m</p>\n        </div>\n        <div className=\"w-14 h-8 rounded-full bg-primary-container p-1 flex items-center shadow-[0_0_15px_rgba(255,126,103,0.3)]\">\n          <div className=\"w-6 h-6 rounded-full bg-on-primary-container translate-x-6 transition-transform shadow-sm\"></div>\n        </div>\n      </div>\n\n      <div className=\"col-span-4 bg-surface/60 backdrop-blur-xl border border-white/20 border-t-white/30 border-l-white/30 rounded-[32px] p-6 relative overflow-hidden glass-card\">\n        <div className=\"absolute -right-4 -bottom-4 w-24 h-24 bg-error/10 rounded-full blur-xl\"></div>\n        <h3 className=\"text-[16px] text-on-surface-variant mb-4 font-medium relative z-10\">Cheat Budget</h3>\n        <div className=\"flex items-end gap-2 relative z-10 w-full mb-4\">\n           <span className=\"text-[32px] font-bold text-error leading-none\">1</span>\n           <span className=\"text-[16px] text-on-surface-variant pb-1 font-medium\">/ 2 Meals</span>\n        </div>\n        <div className=\"w-full bg-surface-container-highest h-2 rounded-full mt-4 overflow-hidden relative z-10\">\n           <div className=\"bg-error w-1/2 h-full rounded-full shadow-[0_0_10px_rgba(255,180,171,0.5)]\"></div>\n        </div>\n      </div>\n    </motion.div>\n  );\n}\n"
    }
