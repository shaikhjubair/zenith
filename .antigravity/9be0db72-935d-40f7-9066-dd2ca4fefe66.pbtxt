  file_change {
    absolute_path_uri: "file:///src/modules/TasksModule.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Pause, Square, CheckSquare, Plus, SquareMenu, Play } from \'lucide-react\';\n\nexport function TasksModule() {\n  const [tasks, setTasks] = useState([\n    { id: 1, title: \'Review API Gateway logs for past 30 days.\', completed: true },\n    { id: 2, title: \'Identify top 3 endpoints causing p99 latency spikes.\', completed: false },\n    { id: 3, title: \'Cross-reference with database query logs.\', completed: false },\n  ]);\n\n  const [queue, setQueue] = useState([\n    { id: 1, title: \'Draft Investor Update\', time: \'60m est.\', color: \'bg-secondary\' },\n    { id: 2, title: \'Review Q2 Analytics\', time: \'30m est.\', color: \'bg-tertiary\' },\n  ]);\n\n  const toggleTask = (id: number) => {\n    setTasks(tasks.map(t => t.id === id ? { ...t, completed: !t.completed } : t));\n  };\n\n  return (\n    <div className=\"max-w-6xl w-full mx-auto grid grid-cols-1 xl:grid-cols-12 gap-8 h-full\">\n      <div className=\"xl:col-span-8 flex flex-col gap-8\">\n        \n        <div className=\"glass-panel rounded-2xl p-8 relative overflow-hidden\">\n          <div className=\"absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl -mr-10 -mt-10 pointer-events-none\"></div>\n          \n          <div className=\"flex justify-between items-start mb-8 relative z-10\">\n            <div>\n              <span className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 text-primary text-xs font-semibold tracking-wide uppercase mb-4 border border-primary/30\">\n                <span className=\"w-2 h-2 rounded-full bg-primary animate-pulse\"></span>\n                In Progress\n              </span>\n              <h3 className=\"text-[64px] font-bold text-on-surface tracking-tight mb-2 leading-none\">Q3 Architecture Review</h3>\n              <p className=\"text-[18px] text-on-surface-variant max-w-xl mt-4\">Deep dive into system diagrams and identify latency bottlenecks in the current microservices mesh.</p>\n            </div>\n            <div className=\"flex gap-2\">\n              <button className=\"w-12 h-12 rounded-xl bg-surface-container hover:bg-white/10 transition-colors text-on-surface flex items-center justify-center shadow-lg border border-white/5\">\n                <Pause className=\"w-6 h-6\" fill=\"currentColor\" />\n              </button>\n              <button className=\"w-12 h-12 rounded-xl bg-surface-container hover:bg-white/10 transition-colors text-on-surface flex items-center justify-center shadow-lg border border-white/5\">\n                <Square className=\"w-6 h-6\" fill=\"currentColor\" />\n              </button>\n            </div>\n          </div>\n\n          <div className=\"flex flex-col md:flex-row items-center gap-12 relative z-10\">\n            <div className=\"relative w-48 h-48 flex items-center justify-center shrink-0\">\n              <svg className=\"w-full h-full transform -rotate-90 absolute inset-0\" viewBox=\"0 0 100 100\">\n                <circle cx=\"50\" cy=\"50\" fill=\"none\" r=\"45\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"4\"></circle>\n                <circle cx=\"50\" cy=\"50\" fill=\"none\" r=\"45\" stroke=\"currentColor\" strokeLinecap=\"round\" strokeWidth=\"4\" className=\"text-primary transition-all duration-1000 ease-linear\" strokeDasharray=\"283\" strokeDashoffset=\"42.45\"></circle>\n              </svg>\n              <div className=\"flex flex-col items-center justify-center relative z-10\">\n                <span className=\"text-5xl font-bold tracking-tighter text-on-surface\">24:15</span>\n                <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider mt-1\">Block 2/4</span>\n              </div>\n            </div>\n\n            <div className=\"flex-1 grid grid-cols-2 md:grid-cols-4 gap-4 w-full\">\n              <div className=\"bg-surface-container-high rounded-xl p-4 flex flex-col items-center gap-2 border-primary/50 relative overflow-hidden shadow-inner\">\n                <div className=\"absolute inset-0 bg-primary/10\"></div>\n                <CheckSquare className=\"text-primary w-6 h-6\" />\n                <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider\">Diagrams</span>\n              </div>\n              <div className=\"bg-surface-container-high rounded-xl p-4 flex flex-col items-center gap-2 border border-primary ring-1 ring-primary/50 shadow-[0_0_15px_rgba(255,180,166,0.15)] transform scale-105 transition-transform\">\n                <Play className=\"text-primary flex-shrink-0 w-6 h-6 animate-pulse\" />\n                <span className=\"text-[12px] font-semibold text-primary uppercase tracking-wider\">Latency</span>\n              </div>\n              <div className=\"bg-surface-container/50 rounded-xl p-4 flex flex-col items-center gap-2 opacity-50 border border-white/5\">\n                <Square className=\"text-on-surface-variant w-6 h-6\" />\n                <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider\">Solutions</span>\n              </div>\n              <div className=\"bg-surface-container/50 rounded-xl p-4 flex flex-col items-center gap-2 opacity-50 border border-white/5\">\n                <Square className=\"text-on-surface-variant w-6 h-6\" />\n                <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider\">Doc</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n          <div className=\"glass-panel rounded-2xl p-6\">\n            <h4 className=\"text-2xl font-medium mb-4 flex items-center gap-2\">\n              <SquareMenu className=\"text-tertiary w-6 h-6\" />\n              Current Context\n            </h4>\n            <ul className=\"flex flex-col gap-3\">\n              <AnimatePresence>\n                {tasks.map(task => (\n                  <motion.li \n                    layout\n                    key={task.id}\n                    className={`flex items-start gap-3 p-3 rounded-lg cursor-pointer transition-colors ${task.completed ? \'hover:bg-white/5 group\' : \'bg-white/5 border border-white/10\'}`}\n                    onClick={() => toggleTask(task.id)}\n                  >\n                    {task.completed ? (\n                       <CheckSquare className=\"text-primary mt-0.5 group-hover:scale-110 transition-transform shrink-0\" />\n                    ) : (\n                       <Square className=\"text-on-surface-variant mt-0.5 shrink-0\" />\n                    )}\n                    <span className={`text-[16px] ${task.completed ? \'text-on-surface-variant line-through opacity-70\' : \'text-on-surface\'}`}>\n                      {task.title}\n                    </span>\n                  </motion.li>\n                ))}\n              </AnimatePresence>\n            </ul>\n          </div>\n\n          <div className=\"glass-panel rounded-2xl p-6 flex flex-col\">\n            <h4 className=\"text-2xl font-medium mb-4 flex items-center gap-2\">\n               <span className=\"material-symbols-outlined text-secondary\">music_note</span>\n               Focus Ambient\n            </h4>\n            <div className=\"flex-1 flex flex-col justify-center items-center bg-surface-container-high/50 rounded-xl border border-white/5 p-4 relative overflow-hidden\">\n               <div className=\"w-16 h-16 rounded-full bg-secondary/20 flex items-center justify-center mb-3 relative z-10 shadow-[0_0_20px_rgba(192,193,255,0.2)]\">\n                  <span className=\"material-symbols-outlined text-secondary text-[32px]\">graphic_eq</span>\n               </div>\n               <span className=\"text-lg font-medium text-on-surface relative z-10 text-center\">Brown Noise + Alpha Waves</span>\n               <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest mt-1 relative z-10\">Playing \342\200\242 42Hz</span>\n               <div className=\"w-full mt-6 flex items-center gap-3 relative z-10 px-4\">\n                  <span className=\"material-symbols-outlined text-on-surface-variant text-sm\">volume_down</span>\n                  <div className=\"h-1.5 flex-1 bg-white/10 rounded-full overflow-hidden\">\n                     <div className=\"h-full w-2/3 bg-secondary rounded-full shadow-[0_0_10px_rgba(192,193,255,0.5)]\"></div>\n                  </div>\n                  <span className=\"material-symbols-outlined text-on-surface-variant text-sm\">volume_up</span>\n               </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"xl:col-span-4 flex flex-col gap-8\">\n        <div className=\"glass-panel rounded-2xl p-6 flex-1\">\n          <div className=\"flex justify-between items-center mb-6\">\n            <h4 className=\"text-2xl font-medium\">Session Queue</h4>\n            <span className=\"text-[12px] font-semibold bg-surface-container-high px-2 py-1 rounded text-on-surface-variant uppercase tracking-wider\">{queue.length} Tasks Left</span>\n          </div>\n          <div className=\"flex flex-col gap-3\">\n             <AnimatePresence>\n               {queue.map(q => (\n                 <motion.div layout key={q.id} className=\"bg-surface-container-high/50 p-4 rounded-xl flex items-start gap-3 border border-white/5 hover:border-white/20 transition-colors cursor-pointer group shadow-sm\">\n                   <div className={`w-2 h-10 rounded-full ${q.color} mt-1`} />\n                   <div className=\"flex-1\">\n                     <h5 className=\"text-[16px] font-medium text-on-surface group-hover:text-primary transition-colors\">{q.title}</h5>\n                     <div className=\"flex items-center gap-2 mt-2\">\n                       <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider\">{q.time}</span>\n                     </div>\n                   </div>\n                   <span className=\"material-symbols-outlined text-on-surface-variant opacity-0 group-hover:opacity-100 transition-opacity\">drag_indicator</span>\n                 </motion.div>\n               ))}\n             </AnimatePresence>\n             <div className=\"p-4 rounded-xl border border-dashed border-white/20 flex items-center justify-center text-on-surface-variant hover:text-on-surface hover:border-white/40 transition-colors cursor-pointer bg-white/5 mt-2\">\n                <Plus className=\"mr-2 w-5 h-5\" />\n                <span className=\"text-[12px] font-semibold uppercase tracking-wider\">Add Block</span>\n             </div>\n          </div>\n        </div>\n\n        <div className=\"glass-panel rounded-2xl p-6\">\n          <h4 className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest mb-4\">Daily Focus Energy</h4>\n          <div className=\"flex items-end gap-2 h-24 mb-2\">\n             <div className=\"flex-1 bg-white/5 rounded-t-sm h-[30%] relative group hover:bg-white/10 transition-colors\"><div className=\"absolute -top-6 left-1/2 -translate-x-1/2 text-[10px] opacity-0 group-hover:opacity-100 transition-opacity font-semibold\">1h</div></div>\n             <div className=\"flex-1 bg-white/5 rounded-t-sm h-[50%] relative group hover:bg-white/10 transition-colors\"><div className=\"absolute -top-6 left-1/2 -translate-x-1/2 text-[10px] opacity-0 group-hover:opacity-100 transition-opacity font-semibold\">2h</div></div>\n             <div className=\"flex-1 bg-primary/40 rounded-t-sm h-[90%] relative group\"><div className=\"absolute -top-6 left-1/2 -translate-x-1/2 text-[10px] text-primary opacity-100 font-semibold shadow-sm\">3.5h</div></div>\n             <div className=\"flex-1 bg-white/10 rounded-t-sm h-[20%] relative group hover:bg-white/20 transition-colors\"><div className=\"absolute -top-6 left-1/2 -translate-x-1/2 text-[10px] opacity-0 group-hover:opacity-100 transition-opacity font-semibold\">45m</div></div>\n             <div className=\"flex-1 bg-white/5 rounded-t-sm h-[10%] relative group hover:bg-white/10 transition-colors\"><div className=\"absolute -top-6 left-1/2 -translate-x-1/2 text-[10px] opacity-0 group-hover:opacity-100 transition-opacity font-semibold\">20m</div></div>\n          </div>\n          <div className=\"flex justify-between font-label-sm text-[10px] text-on-surface-variant/50\">\n             <span>8 AM</span>\n             <span>12 PM</span>\n             <span>4 PM</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
