    replacement_chunks {
      target_content: "import { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Sidebar } from \'./components/Sidebar\';\nimport { TopBar } from \'./components/TopBar\';\n\n// The 8 distinct modules\ntype ModuleID = \'study\' | \'skills\' | \'tasks\' | \'expense\' | \'diet\' | \'spiritual\' | \'sports\' | \'library\';\n\n// These modules require a PIN to access\nconst PROTECTED_MODULES: ModuleID[] = [\'study\', \'expense\', \'diet\'];\n\nfunction App() {\n  const [activeModule, setActiveModule] = useState<ModuleID>(\'tasks\');\n  const [unlockedModules, setUnlockedModules] = useState<Record<string, boolean>>({});\n\n  const handleUnlock = (moduleId: ModuleID) => {\n    setUnlockedModules(prev => ({ ...prev, [moduleId]: true }));\n  };\n\n  const isModuleLocked = (moduleId: ModuleID) => {\n    return PROTECTED_MODULES.includes(moduleId) && !unlockedModules[moduleId];\n  };\n\n  const renderModule = () => {\n    // Placeholder for actual module components\n    const locked = isModuleLocked(activeModule);\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center\">\n        <h2 className=\"text-4xl font-bold mb-4 capitalize\">{activeModule} Module</h2>\n        <p className=\"text-on-surface-variant text-lg\">\n          {locked ? \"This module is locked\" : \"This module is unlocked\"}\n        </p>\n      </div>\n    );\n  };\n\n  return (\n    <div className=\"relative min-h-screen text-on-surface aurora-bg selection:bg-primary/30 font-sans overflow-x-hidden flex\">\n      <Sidebar activeModule={activeModule} onModuleChange={setActiveModule} isLocked={isModuleLocked} />\n      \n      <main className=\"flex-1 flex flex-col relative z-10 min-h-screen pl-6 lg:pl-0 pt-6 pb-6 pr-6 lg:ml-64 w-full transition-all duration-300\">\n        <TopBar />\n        \n        <div className=\"flex-1 mt-8 relative w-full h-[calc(100vh-140px)] overflow-y-auto scrollbar-thin scrollbar-thumb-white/10 scrollbar-track-transparent\">\n          <AnimatePresence mode=\"wait\">\n            <motion.div\n              key={activeModule}\n              initial={{ opacity: 0, y: 20, filter: \'blur(10px)\' }}\n              animate={{ opacity: 1, y: 0, filter: \'blur(0px)\' }}\n              exit={{ opacity: 0, y: -20, filter: \'blur(10px)\' }}\n              transition={{ duration: 0.4, ease: [0.22, 1, 0.36, 1] }}\n              className=\"absolute inset-0 pb-12 h-screen\"\n            >\n              {renderModule()}\n            </motion.div>\n          </AnimatePresence>\n        </div>\n      </main>\n    </div>\n  );\n}\n\nexport default App;"
      replacement_content: "import { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Sidebar } from \'./components/Sidebar\';\nimport { TopBar } from \'./components/TopBar\';\n\n// Modules\nimport { StudyModule } from \'./modules/StudyModule\';\nimport { SkillsModule } from \'./modules/SkillsModule\';\nimport { TasksModule } from \'./modules/TasksModule\';\nimport { ExpenseModule } from \'./modules/ExpenseModule\';\nimport { DietModule } from \'./modules/DietModule\';\nimport { SpiritualModule } from \'./modules/SpiritualModule\';\nimport { SportsModule } from \'./modules/SportsModule\';\nimport { LibraryModule } from \'./modules/LibraryModule\';\n\n// The 8 distinct modules\ntype ModuleID = \'study\' | \'skills\' | \'tasks\' | \'expense\' | \'diet\' | \'spiritual\' | \'sports\' | \'library\';\n\n// These modules require a PIN to access\nconst PROTECTED_MODULES: ModuleID[] = [\'study\', \'expense\', \'diet\'];\n\nfunction App() {\n  const [activeModule, setActiveModule] = useState<ModuleID>(\'tasks\');\n  const [unlockedModules, setUnlockedModules] = useState<Record<string, boolean>>({});\n\n  const handleUnlock = (moduleId: ModuleID) => {\n    setUnlockedModules(prev => ({ ...prev, [moduleId]: true }));\n  };\n\n  const isModuleLocked = (moduleId: ModuleID) => {\n    return PROTECTED_MODULES.includes(moduleId) && !unlockedModules[moduleId];\n  };\n\n  const renderModule = () => {\n    switch (activeModule) {\n      case \'study\':\n        return <StudyModule isUnlocked={!isModuleLocked(\'study\')} onUnlock={() => handleUnlock(\'study\')} />;\n      case \'skills\':\n        return <SkillsModule />;\n      case \'tasks\':\n        return <TasksModule />;\n      case \'expense\':\n        return <ExpenseModule isUnlocked={!isModuleLocked(\'expense\')} onUnlock={() => handleUnlock(\'expense\')} />;\n      case \'diet\':\n        return <DietModule isUnlocked={!isModuleLocked(\'diet\')} onUnlock={() => handleUnlock(\'diet\')} />;\n      case \'spiritual\':\n        return <SpiritualModule />;\n      case \'sports\':\n        return <SportsModule />;\n      case \'library\':\n        return <LibraryModule />;\n      default:\n        return <div className=\"text-white\">Module not found</div>;\n    }\n  };\n\n  return (\n    <div className=\"relative min-h-screen text-on-surface aurora-bg selection:bg-primary/30 font-sans overflow-x-hidden flex\">\n      <Sidebar activeModule={activeModule} onModuleChange={setActiveModule} isLocked={isModuleLocked} />\n      \n      <main className=\"flex-1 flex flex-col relative z-10 min-h-screen pl-6 lg:pl-0 pt-6 pb-6 pr-6 lg:ml-64 w-full transition-all duration-300\">\n        <TopBar />\n        \n        <div className=\"flex-1 mt-8 relative w-full h-[calc(100vh-140px)] overflow-y-auto scrollbar-thin scrollbar-thumb-white/10 scrollbar-track-transparent\">\n          <AnimatePresence mode=\"wait\">\n            <motion.div\n              key={activeModule}\n              initial={{ opacity: 0, y: 20, filter: \'blur(10px)\' }}\n              animate={{ opacity: 1, y: 0, filter: \'blur(0px)\' }}\n              exit={{ opacity: 0, y: -20, filter: \'blur(10px)\' }}\n              transition={{ duration: 0.4, ease: [0.22, 1, 0.36, 1] }}\n              className=\"absolute inset-0 pb-12 h-screen\"\n            >\n              {renderModule()}\n            </motion.div>\n          </AnimatePresence>\n        </div>\n      </main>\n    </div>\n  );\n}\n\nexport default App;"
    }
    instruction: "Import the right modules and render them inside the content area."
  }
}
