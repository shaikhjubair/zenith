    absolute_path_uri: "file:///src/modules/ExpenseModule.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \'motion/react\';\nimport { PinLock } from \'../components/PinLock\';\n\nexport function ExpenseModule({ isUnlocked, onUnlock }: { isUnlocked: boolean, onUnlock: () => void }) {\n  if (!isUnlocked) {\n    return (\n      <div className=\"relative flex-1 flex items-center justify-center -m-8 px-8\">\n        <div className=\"absolute inset-0 opacity-20 blur-md pointer-events-none p-10 flex flex-col gap-6 w-full\">\n           <div className=\"grid grid-cols-3 gap-6\">\n             <div className=\"glass-panel rounded-xl h-48 w-full\"></div>\n             <div className=\"glass-panel rounded-xl h-48 col-span-2 w-full\"></div>\n           </div>\n           <div className=\"grid grid-cols-2 gap-6 flex-grow h-full\">\n             <div className=\"glass-panel rounded-xl w-full\"></div>\n             <div className=\"glass-panel rounded-xl w-full\"></div>\n           </div>\n        </div>\n        <PinLock \n          moduleName=\"Expense\" \n          description=\"Enter your secure PIN to access the Expense ledger.\" \n          onUnlock={onUnlock} \n        />\n      </div>\n    );\n  }\n\n  return (\n    <motion.div \n      initial={{ opacity: 0 }} animate={{ opacity: 1 }} \n      className=\"max-w-6xl w-full mx-auto flex flex-col gap-8 h-full\"\n    >\n        <div className=\"flex justify-between items-center mb-2\">\n            <div>\n              <h2 className=\"text-[32px] font-bold text-on-surface tracking-tight leading-none mb-1\">Expense Ledger</h2>\n              <p className=\"text-[16px] text-on-surface-variant\">Manage liquidity and allocations.</p>\n            </div>\n            <button className=\"bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-semibold uppercase tracking-wider flex items-center gap-2 hover:bg-primary/20 transition-colors border border-primary/20\">\n                <span className=\"material-symbols-outlined text-[18px]\">add</span>\n                New Transaction\n            </button>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n            <div className=\"glass-card rounded-2xl p-6 mesh-income relative overflow-hidden group hover:border-[#00e676]/50 transition-colors shadow-lg\">\n                <div className=\"absolute top-0 right-0 w-32 h-32 bg-[#00e676]/10 rounded-full blur-3xl -mr-10 -mt-10\"></div>\n                <div className=\"flex justify-between items-start mb-4 relative z-10\">\n                    <div className=\"w-10 h-10 rounded-xl bg-[#00e676]/20 flex items-center justify-center text-[#00e676] border border-[#00e676]/30\">\n                        <span className=\"material-symbols-outlined\">account_balance</span>\n                    </div>\n                    <span className=\"px-3 py-1 rounded-full bg-[#00e676]/10 text-[#00e676] text-[12px] font-bold border border-[#00e676]/20\">+12.5%</span>\n                </div>\n                <div className=\"relative z-10\">\n                    <p className=\"text-on-surface-variant text-[12px] font-semibold mb-1 uppercase tracking-wider\">Total Balance</p>\n                    <h2 className=\"text-[64px] font-bold text-on-surface tracking-tight leading-none\">$42,590<span className=\"text-on-surface-variant text-[32px]\">.00</span></h2>\n                </div>\n            </div>\n\n            <div className=\"glass-card rounded-2xl p-6 mesh-expense relative overflow-hidden group hover:border-[#ff5252]/50 transition-colors shadow-lg\">\n                <div className=\"absolute top-0 right-0 w-32 h-32 bg-[#ff5252]/10 rounded-full blur-3xl -mr-10 -mt-10\"></div>\n                <div className=\"flex justify-between items-start mb-4 relative z-10\">\n                    <div className=\"w-10 h-10 rounded-xl bg-[#ff5252]/20 flex items-center justify-center text-[#ff5252] border border-[#ff5252]/30\">\n                        <span className=\"material-symbols-outlined\">trending_down</span>\n                    </div>\n                    <span className=\"px-3 py-1 rounded-full bg-[#ff5252]/10 text-[#ff5252] text-[12px] font-bold border border-[#ff5252]/20\">-4.2%</span>\n                </div>\n                <div className=\"relative z-10\">\n                    <p className=\"text-on-surface-variant text-[12px] font-semibold mb-1 uppercase tracking-wider\">Monthly Spend</p>\n                    <h2 className=\"text-[32px] font-bold text-on-surface tracking-tight mt-2\">$3,240<span className=\"text-on-surface-variant text-[18px]\">.50</span></h2>\n                </div>\n            </div>\n\n            <div className=\"glass-card rounded-2xl p-6 mesh-p2p relative overflow-hidden group hover:border-[#651fff]/50 transition-colors shadow-lg\">\n                <div className=\"absolute top-0 right-0 w-32 h-32 bg-[#651fff]/10 rounded-full blur-3xl -mr-10 -mt-10\"></div>\n                <div className=\"flex justify-between items-start mb-4 relative z-10\">\n                    <div className=\"w-10 h-10 rounded-xl bg-[#651fff]/20 flex items-center justify-center text-[#651fff] border border-[#651fff]/30\">\n                        <span className=\"material-symbols-outlined\">handshake</span>\n                    </div>\n                    <span className=\"px-3 py-1 rounded-full bg-[#651fff]/10 text-[#651fff] text-[12px] font-bold border border-[#651fff]/20\">Active</span>\n                </div>\n                <div className=\"relative z-10\">\n                    <p className=\"text-on-surface-variant text-[12px] font-semibold mb-1 uppercase tracking-wider\">Lent Out</p>\n                    <h2 className=\"text-[32px] font-bold text-on-surface tracking-tight mt-2\">$1,500<span className=\"text-on-surface-variant text-[18px]\">.00</span></h2>\n                </div>\n            </div>\n        </div>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 flex-1 min-h-[400px]\">\n            <div className=\"lg:col-span-2 glass-card rounded-2xl p-6 flex flex-col\">\n                <div className=\"flex justify-between items-center mb-6\">\n                    <h3 className=\"text-2xl font-medium text-on-surface\">Recent Ledger</h3>\n                    <button className=\"text-primary text-xs font-semibold hover:underline uppercase tracking-wider\">View All</button>\n                </div>\n                <div className=\"flex-grow overflow-y-auto pr-2 space-y-4\">\n                    {[\n                       { title: \'Whole Foods Market\', subtitle: \'Groceries \342\200\242 Today, 2:30 PM\', amount: \'-$142.50\', color: \'text-[#ff5252]\', bg: \'bg-[#ff5252]\', icon: \'shopping_cart\' },\n                       { title: \'Tech Corp Inc.\', subtitle: \'Salary \342\200\242 Yesterday\', amount: \'+$4,200.00\', color: \'text-[#00e676]\', bg: \'bg-[#00e676]\', icon: \'work\' },\n                       { title: \'Alex Johnson\', subtitle: \'P2P Loan \342\200\242 Oct 24\', amount: \'-$500.00\', color: \'text-[#651fff]\', bg: \'bg-[#651fff]\', icon: \'arrow_upward\' },\n                       { title: \'Electric Utility\', subtitle: \'Bills \342\200\242 Oct 22\', amount: \'-$85.20\', color: \'text-[#ffb4a6]\', bg: \'bg-[#ffab00]\', icon: \'bolt\' }\n                    ].map((tx, i) => (\n                        <div key={i} className=\"flex items-center justify-between p-4 rounded-xl bg-surface/30 border border-white/5 hover:bg-surface/50 transition-colors\">\n                            <div className=\"flex items-center gap-4\">\n                                <div className={`w-12 h-12 rounded-full ${tx.bg}/10 flex items-center justify-center ${tx.color} border border-current/20`}>\n                                    <span className=\"material-symbols-outlined\">{tx.icon}</span>\n                                </div>\n                                <div>\n                                    <p className=\"font-bold text-on-surface\">{tx.title}</p>\n                                    <p className=\"text-sm text-on-surface-variant\">{tx.subtitle}</p>\n                                </div>\n                            </div>\n                            <div className=\"text-right\">\n                                <p className={`font-bold ${tx.color}`}>{tx.amount}</p>\n                            </div>\n                        </div>\n                    ))}\n                </div>\n            </div>\n\n            <div className=\"glass-card rounded-2xl p-6 flex flex-col\">\n                <h3 className=\"text-2xl font-medium text-on-surface mb-6\">Spending Hub</h3>\n                <div className=\"flex-grow flex flex-col gap-6\">\n                    <div>\n                        <div className=\"flex justify-between text-sm mb-2 font-medium\">\n                            <span className=\"text-on-surface flex items-center gap-2\">\n                                <div className=\"w-3 h-3 rounded-full bg-[#ff5252] shadow-[0_0_10px_rgba(255,82,82,0.5)]\"></div>\n                                Housing\n                            </span>\n                            <span className=\"text-on-surface-variant\">$1,200</span>\n                        </div>\n                        <div className=\"w-full bg-surface/50 rounded-full h-2 border border-white/5 overflow-hidden\">\n                            <div className=\"bg-[#ff5252] h-full rounded-full shadow-[0_0_10px_rgba(255,82,82,0.5)]\" style={{width: \'45%\'}}></div>\n                        </div>\n                    </div>\n\n                    <div>\n                        <div className=\"flex justify-between text-sm mb-2 font-medium\">\n                            <span className=\"text-on-surface flex items-center gap-2\">\n                                <div className=\"w-3 h-3 rounded-full bg-[#ffab00] shadow-[0_0_10px_rgba(255,171,0,0.5)]\"></div>\n                                Food & Dining\n                            </span>\n                            <span className=\"text-on-surface-var