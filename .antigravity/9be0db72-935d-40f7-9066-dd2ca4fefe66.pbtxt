      replacement_content: "import { motion } from \'motion/react\';\nimport { CalendarDays, Sun, Heart, Moon, BookOpen, Quote } from \'lucide-react\';\n\nexport function SpiritualModule() {\n  return (\n    <div className=\"max-w-6xl w-full mx-auto flex flex-col h-full gap-8\">\n      <header className=\"mb-2\">\n        <h2 className=\"text-[64px] font-bold text-on-surface mb-2 tracking-tight leading-none\">Spiritual Sanctuary</h2>\n        <p className=\"text-[18px] text-on-surface-variant\">Cultivate inner peace and track your daily devotionals.</p>\n      </header>\n      \n      <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-8 flex-1\">\n        <div className=\"xl:col-span-8 flex flex-col gap-8\">\n          <section className=\"glass-card rounded-2xl p-8 relative overflow-hidden\">\n            <div className=\"absolute -top-20 -right-20 w-64 h-64 bg-primary/10 rounded-full blur-[60px] pointer-events-none\"></div>\n            \n            <div className=\"flex justify-between items-end mb-8 relative z-10\">\n              <div>\n                <h3 className=\"text-[24px] font-medium text-primary flex items-center gap-2 mb-2\">\n                  <CalendarDays className=\"w-6 h-6\" />\n                  Prayer Consistency\n                </h3>\n                <p className=\"text-[16px] text-on-surface-variant\">Farz, Nafl, and Tahajjud tracking over the last quarter.</p>\n              </div>\n              <div className=\"flex gap-4 text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">\n                <div className=\"flex items-center gap-2\"><span className=\"w-3 h-3 rounded-sm bg-surface-container-high border border-white/5\"></span> Missed</div>\n                <div className=\"flex items-center gap-2\"><span className=\"w-3 h-3 rounded-sm bg-primary/30 border border-primary/20\"></span> Partial</div>\n                <div className=\"flex items-center gap-2\"><span className=\"w-3 h-3 rounded-sm bg-primary border border-primary/50 shadow-[0_0_8px_rgba(255,180,166,0.6)]\"></span> Perfect</div>\n              </div>\n            </div>\n\n            <div className=\"overflow-x-auto pb-4 relative z-10\">\n              <div className=\"flex gap-[6px] min-w-max\">\n                {Array.from({ length: 16 }).map((_, w) => (\n                  <div key={w} className=\"flex flex-col gap-[6px]\">\n                    {Array.from({ length: 7 }).map((_, d) => {\n                       const intensity = Math.random() > 0.7 ? 3 : Math.random() > 0.4 ? 2 : Math.random() > 0.2 ? 1 : 0;\n                       let colorClass = \'bg-surface-container-high border-white/5\';\n                       if (intensity === 1) colorClass = \'bg-primary/20 border-primary/20\';\n                       if (intensity === 2) colorClass = \'bg-primary/50 border-primary/40\';\n                       if (intensity === 3) colorClass = \'bg-primary border-primary/50 shadow-[0_0_8px_rgba(255,180,166,0.4)]\';\n                       \n                       return (\n                         <div key={d} className={`w-[18px] h-[18px] rounded-sm border ${colorClass} hover:scale-125 hover:z-10 transition-transform cursor-pointer`}></div>\n                       )\n                    })}\n                  </div>\n                ))}\n              </div>\n            </div>\n          </section>\n\n          <section className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n            <div className=\"glass-card rounded-[32px] p-6 flex flex-col justify-between hover:-translate-y-1 transition-transform\">\n              <div>\n                <div className=\"flex justify-between items-start mb-6\">\n                  <div className=\"w-12 h-12 rounded-full bg-primary-container/20 flex items-center justify-center text-primary-container border border-primary-container/30\">\n                    <Sun className=\"w-6 h-6\" />\n                  </div>\n                  <span className=\"text-[12px] font-semibold px-3 py-1 bg-surface-container-high rounded-full text-on-surface-variant border border-white/5 uppercase tracking-widest\">Daily</span>\n                </div>\n                <h4 className=\"text-[24px] font-medium text-on-surface\">Farz</h4>\n                <p className=\"text-[16px] text-on-surface-variant mt-1\">Obligatory prayers</p>\n              </div>\n              <div className=\"mt-8\">\n                <div className=\"flex justify-between text-[12px] font-semibold mb-2 text-on-surface uppercase tracking-widest\">\n                  <span>Today</span>\n                  <span>4/5</span>\n                </div>\n                <div className=\"w-full h-2 bg-surface-container-highest rounded-full overflow-hidden\">\n                  <div className=\"h-full bg-primary rounded-full shadow-[0_0_10px_rgba(255,180,166,0.4)]\" style={{width: \'80%\'}}></div>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"glass-card rounded-[32px] p-6 flex flex-col justify-between hover:-translate-y-1 transition-transform\">\n              <div>\n                <div className=\"flex justify-between items-start mb-6\">\n                  <div className=\"w-12 h-12 rounded-full bg-tertiary-container/20 flex items-center justify-center text-tertiary-container border border-tertiary-container/30\">\n                    <Heart className=\"w-6 h-6\" />\n                  </div>\n                  <span className=\"text-[12px] font-semibold px-3 py-1 bg-surface-container-high rounded-full text-on-surface-variant border border-white/5 uppercase tracking-widest\">Voluntary</span>\n                </div>\n                <h4 className=\"text-[24px] font-medium text-on-surface\">Nafl</h4>\n                <p className=\"text-[16px] text-on-surface-variant mt-1\">Additional devotionals</p>\n              </div>\n              <div className=\"mt-8\">\n                <div className=\"flex justify-between text-[12px] font-semibold mb-2 text-on-surface uppercase tracking-widest\">\n                  <span>Today</span>\n                  <span>2/4</span>\n                </div>\n                <div className=\"w-full h-2 bg-surface-container-highest rounded-full overflow-hidden\">\n                  <div className=\"h-full bg-tertiary rounded-full shadow-[0_0_10px_rgba(137,206,255,0.4)]\" style={{width: \'50%\'}}></div>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"glass-card rounded-[32px] p-6 flex flex-col justify-between relative overflow-hidden group hover:-translate-y-1 transition-transform\">\n              <div className=\"absolute inset-0 bg-gradient-to-br from-secondary/10 to-transparent opacity-50 group-hover:opacity-100 transition-opacity\"></div>\n              <div className=\"relative z-10\">\n                <div className=\"flex justify-between items-start mb-6\">\n                  <div className=\"w-12 h-12 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary border border-secondary/30\">\n                    <Moon className=\"w-6 h-6\" />\n                  </div>\n                  <span className=\"text-[12px] font-semibold px-3 py-1 bg-surface-container-high rounded-full text-on-surface-variant border border-white/5 uppercase tracking-widest\">Night</span>\n                </div>\n                <h4 className=\"text-[24px] font-medium text-on-surface\">Tahajjud</h4>\n                <p className=\"text-[16px] text-on-surface-variant mt-1\">Pre-dawn connection</p>\n              </div>\n              <div className=\"mt-8 relative z-10\">\n                <div className=\"flex items-center gap-2 text-[12px] font-bold text-secondary uppercase tracking-widest\">\n                  <span className=\"material-symbols-outlined text-[16px]\">done_all</span>\n                  <span>Completed 3:30 AM</span>\n                </div>\n              </div>\n            </div>\n          </section>\n        </div>\n\n        <div className=\"xl:col-span-4 flex flex-col gap-8\">\n          <section className=\"glass-card rounded-2xl p-8\">\n            <h3 className=\"text-[24px] font-medium text-on-surface mb-8 flex items-center gap-3\">\n              <BookOpen className=\"text-tertiary w-6 h-6\" />\n              Sacred Texts\n            </h3>\n            <div className=\"space-y-8\">\n              <div>\n                <div className=\"flex justify-between items-center mb-3\">\n                  <div>\n                    <h5 className=\"text-[16px] font-semibold text-on-surface mb-1\">Quran</h5>\n                    <p className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">Juz 15, Surah Al-Isra</p>\n                  </div>\n                  <span className=\"text-[12px] font-bold text-tertiary font-mono\">45%</span>\n                </div>\n                <div className=\"w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden relative\">\n                  <div className=\"absolute inset-y-0 left-0 bg-gradient-to-r from-tertiary to-secondary rounded-full\" style={{width: \'45%\'}}></div>\n                </div>\n              </div>\n\n              <div>\n                <div className=\"flex justify-between items-center mb-3\">\n                  <div>\n                    <h5 className=\"text-[16px] font-semibold text-on-surface mb-1\">Riyad as-Salihin</h5>\n                    <p className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">Chapter 12: Good Conduct</p>\n                  </div>\n                  <span className=\"text-[12px] font-bold text-primary font-mono\">12%</span>\n                </div>\n                <div className=\"w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden\">\n                  <div className=\"h-full bg-primary rounded-full\" style={{width: \'12%\'}}></div>\n                </div>\n              </div>\n            </div>\n            <button className=\"mt-8 w-full py-3 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-[12px] font-bold uppercase tracking-widest text-on-surface shadow-sm\">\n              Log Reading Session\n            </button>\n          </section>\n\n          <section className=\"glass-card rounded-2xl p-8 relative overflow-hidden flex-1 min-h-[250px] flex flex-col justify-center shadow-lg border border-white/5\">\n            <div className=\"absolute inset-0 bg-gradient-to-br from-surface-container-lowest to-surface-container opacity-80\"></div>\n            <div className=\"absolute top-0 right-0 p-6 opacity-10 text-on-surface\">\n              <Quote size={64} fill=\"currentColor\" />\n            </div>\n            <div className=\"relative z-10\">\n              <p className=\"text-[24px] text-on-surface font-medium italic leading-relaxed text-balance\">\n                \"And He found you lost and guided [you].\"\n              </p>\n              <p className=\"text-[12px] text-on-surface-variant mt-6 font-mono tracking-widest uppercase font-semibold\">\n                Ad-Duha 93:7\n              </p>\n            </div>\n          </section>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
