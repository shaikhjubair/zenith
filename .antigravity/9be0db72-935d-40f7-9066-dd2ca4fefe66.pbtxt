    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \'motion/react\';\nimport { History, MoreVertical, Accessibility, Shell, Plus } from \'lucide-react\';\n\nexport function SportsModule() {\n  return (\n    <div className=\"max-w-[1400px] w-full mx-auto flex flex-col h-full gap-8\">\n      <header className=\"flex justify-between items-end mb-2\">\n        <h2 className=\"text-[32px] font-bold text-primary tracking-tight leading-none\">Sports & Action</h2>\n      </header>\n\n      <div className=\"grid grid-cols-12 gap-8 flex-1\">\n        <div className=\"col-span-12 lg:col-span-8 glass-card rounded-[24px] p-8 flex flex-col justify-between relative overflow-hidden group shadow-lg\">\n          <div className=\"absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-50\"></div>\n          <div className=\"relative z-10 flex justify-between items-start mb-8\">\n            <div>\n              <h3 className=\"text-[32px] font-bold mb-2 text-on-surface\">Today\'s Focus</h3>\n              <p className=\"text-[16px] text-on-surface-variant\">Core & Upper Body Hypertrophy</p>\n            </div>\n            <button className=\"bg-primary text-on-primary px-6 py-3 rounded-xl text-[12px] uppercase tracking-widest font-bold flex items-center gap-2 hover:opacity-90 transition-opacity shadow-[0_4px_15px_rgba(255,180,166,0.3)]\">\n              <span className=\"material-symbols-outlined text-[18px]\">play_arrow</span>\n              Start Session\n            </button>\n          </div>\n          \n          <div className=\"relative z-10 grid grid-cols-3 gap-6 mt-auto\">\n            <div className=\"bg-surface-container-low/50 p-6 rounded-2xl border border-white/5 backdrop-blur-md\">\n              <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest block mb-2\">Volume Load</span>\n              <span className=\"text-[32px] font-bold text-primary tracking-tight\">4,200 kg</span>\n            </div>\n            <div className=\"bg-surface-container-low/50 p-6 rounded-2xl border border-white/5 backdrop-blur-md\">\n              <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest block mb-2\">Intensity</span>\n              <span className=\"text-[32px] font-bold text-tertiary tracking-tight\">85%</span>\n            </div>\n            <div className=\"bg-surface-container-low/50 p-6 rounded-2xl border border-white/5 backdrop-blur-md\">\n              <span className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest block mb-2\">Est. Time</span>\n              <span className=\"text-[32px] font-bold text-on-surface tracking-tight\">45 min</span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"col-span-12 lg:col-span-4 glass-card rounded-[24px] p-8 flex flex-col shadow-lg border border-white/10\">\n          <div className=\"flex justify-between items-center mb-8\">\n            <h3 className=\"text-[24px] font-medium text-on-surface\">Consistency</h3>\n            <span className=\"text-[12px] font-bold text-primary uppercase tracking-widest\">Nov 2023</span>\n          </div>\n          <div className=\"flex-1 flex flex-col justify-center\">\n            <div className=\"grid grid-cols-7 gap-2 mb-3 text-center text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest w-full px-2\">\n              <div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div><div>S</div>\n            </div>\n            <div className=\"grid grid-cols-7 gap-2 px-2\">\n              {Array.from({ length: 28 }).map((_, i) => {\n                 const heat = Math.random();\n                 let color = \'bg-white/5\';\n                 if (heat > 0.8) color = \'bg-primary shadow-[0_0_8px_rgba(255,180,166,0.6)]\';\n                 else if (heat > 0.5) color = \'bg-primary/70\';\n                 else if (heat > 0.2) color = \'bg-primary/40\';\n                 else if (heat > 0.1) color = \'bg-primary/20\';\n\n                 return <div key={i} className={`aspect-square rounded-md ${color} hover:scale-110 transition-transform`}></div>\n              })}\n            </div>\n          </div>\n          <div className=\"mt-8 flex items-center justify-between text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest px-2\">\n            <span>Less</span>\n            <div className=\"flex gap-1.5\">\n              <div className=\"w-4 h-4 rounded-sm bg-white/5\"></div>\n              <div className=\"w-4 h-4 rounded-sm bg-primary/20\"></div>\n              <div className=\"w-4 h-4 rounded-sm bg-primary/40\"></div>\n              <div className=\"w-4 h-4 rounded-sm bg-primary/70\"></div>\n              <div className=\"w-4 h-4 rounded-sm bg-primary\"></div>\n            </div>\n            <span>More</span>\n          </div>\n        </div>\n\n        <div className=\"col-span-12 glass-card rounded-[32px] p-10 shadow-xl border border-white/10\">\n          <div className=\"flex items-center justify-between mb-10\">\n            <h3 className=\"text-[24px] font-medium text-on-surface mt-2\">Session Inputs</h3>\n            <div className=\"flex gap-3\">\n              <button className=\"w-12 h-12 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors text-on-surface flex items-center justify-center border border-white/5 shadow-sm\">\n                <History className=\"w-5 h-5\" />\n              </button>\n              <button className=\"w-12 h-12 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors text-on-surface flex items-center justify-center border border-white/5 shadow-sm\">\n                <MoreVertical className=\"w-5 h-5\" />\n              </button>\n            </div>\n          </div>\n\n          <div className=\"space-y-8\">\n            <div className=\"bg-surface-container-lowest/30 rounded-[24px] p-8 border border-white/5 backdrop-blur-sm\">\n              <div className=\"flex items-center gap-6 mb-8\">\n                <div className=\"w-16 h-16 rounded-2xl bg-primary/20 flex items-center justify-center text-primary border border-primary/30\">\n                  <Accessibility className=\"w-8 h-8\" />\n                </div>\n                <div>\n                  <h4 className=\"text-[20px] font-bold text-on-surface mb-1\">Push-ups</h4>\n                  <p className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">Chest, Triceps, Shoulders</p>\n                </div>\n              </div>\n              <div className=\"overflow-x-auto\">\n                <table className=\"w-full text-left border-collapse min-w-[600px]\">\n                  <thead>\n                    <tr className=\"text-[12px] font-semibold text-on-surface-variant border-b border-white/10 uppercase tracking-widest\">\n                      <th className=\"pb-4 w-20\">Set</th>\n                      <th className=\"pb-4 px-6\">Target Reps</th>\n                      <th className=\"pb-4 px-6\">Actual Reps</th>\n                      <th className=\"pb-4 px-6\">Weight (kg)</th>\n                      <th className=\"pb-4 text-right\">Status</th>\n                    </tr>\n                  </thead>\n                  <tbody className=\"text-[16px]\">\n                    <tr className=\"border-b border-white/5 hover:bg-white/5 transition-colors\">\n                      <td className=\"py-4 text-on-surface-variant font-medium\">1</td>\n                      <td className=\"py-4 px-6 text-on-surface-variant font-medium\">20</td>\n                      <td className=\"py-4 px-6\">\n                        <input type=\"number\" defaultValue=\"20\" className=\"w-24 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-center font-bold text-on-surface focus:outline-none focus:border-primary focus:bg-primary/10 transition-colors\" />\n                      </td>\n                      <td className=\"py-4 px-6\">\n                        <input type=\"number\" defaultValue=\"0\" className=\"w-24 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-center text-on-surface focus:outline-none focus:border-primary transition-colors\" />\n                      </td>\n                      <td className=\"py-4 text-right\">\n                        <span className=\"material-symbols-outlined text-tertiary\">check_circle</span>\n                      </td>\n                    </tr>\n                    <tr className=\"hover:bg-white/5 transition-colors\">\n                      <td className=\"py-4 text-on-surface-variant font-medium\">2</td>\n                      <td className=\"py-4 px-6 text-on-surface-variant font-medium\">15</td>\n                      <td className=\"py-4 px-6\">\n                        <input type=\"number\" placeholder=\"-\" className=\"w-24 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-center font-bold text-on-surface focus:outline-none focus:border-primary focus:bg-primary/10 transition-colors\" />\n                      </td>\n                      <td className=\"py-4 px-6\">\n                        <input type=\"number\" defaultValue=\"0\" className=\"w-24 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-center text-on-surface focus:outline-none focus:border-primary transition-colors\" />\n                      </td>\n                      <td className=\"py-4 text-right\">\n                        <span className=\"material-symbols-outlined text-on-surface-variant opacity-30\">check_circle</span>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n              <button className=\"mt-6 text-primary text-[12px] font-bold uppercase tracking-widest hover:underline flex items-center gap-2\">\n                <Plus className=\"w-4 h-4\" /> Add Set\n              </button>\n            </div>\n\n            <div className=\"bg-surface-container-lowest/30 rounded-[24px] p-8 border border-white/5 backdrop-blur-sm\">\n              <div className=\"flex items-center gap-6 mb-8\">\n                <div className=\"w-16 h-16 rounded-2xl bg-tertiary/20 flex items-center justify-center text-tertiary border border-tertiary/30\">\n                  <Shell className=\"w-8 h-8\" />\n                </div>\n                <div>\n                  <h4 className=\"text-[20px] font-bold text-on-surface mb-1\">Core Reduction (Plank)</h4>\n                  <p className=\"text-[12px] font-semibold text-on-surface-variant uppercase tracking-widest\">Abdominals, Stabilizers</p>\n                </div>\n              </div>\n              <div className=\"overflow-x-auto\">\n                <table className=\"w-full text-left border-collapse min-w-[600px]\">\n                  <thead>\n                    <tr className=\"text-[12px] font-semibold text-on-surface-variant border-b border-white/10 uppercase tracking-widest\">\n                      <th className=\"pb-4 w-20\">Set</th>\n                      <th className=\"pb-4 px-6\">Target Time</th>\n                      <th className=\"pb-4 px-6\">Actual Time</th>\n                      <th className=\"pb-4 text-right\">Status</th>\n                    </tr>\n                  </thead>\n                  <tbody className=\"text-[16px]\">\n                    <tr className=\"hover:bg-white/5 transition-colors\">\n                      <td className=\"py-4 text-on-surface-variant font-medium\">1</td>\n                      <td className=\"py-4 px-6 text-on-surface-variant font-medium\">60s</td>\n                      <td className=\"py-4 px-6\">\n                        <input type=\"text\" placeholder=\"e.g. 60s\" className=\"w-32 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-center font-bold text-on-surface focus:outline-none focus:border-primary focus:bg-primary/10 transition-colors\" />\n                      </td>\n                      <td className=\"py-4 text-right\">\n                        <span className=\"material-symbols-outlined text-on-surface-variant opacity-30\">check_circle</span>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n              <button className=\"mt-6 text-primary text-[12px] font-bold uppercase tracking-widest hover:underline flex items-center gap-2\">\n                <Plus className=\"w-4 h-4\" /> Add Set\n              </button>\n            </div>\n          </div>\n\n          <div className=\"mt-12 flex justify-end gap-4\">\n             <button className=\"bg-surface-container text-on-surface px-8 py-3.5 rounded-xl text-[12px] font-bold uppercase tracking-widest border border-white/10 hover:bg-white/10 transition-colors shadow-sm\">\n                Save Draft\n             </button>\n             <button className=\"bg-primary text-on-primary px-8 py-3.5 rounded-xl text-[12px] font-bold uppercase tracking-widest hover:opacity-90 transition-opacity shadow-[0_4px_20px_rgba(255,180,166,0.4)]\">\n                Complete Workout\n             </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
